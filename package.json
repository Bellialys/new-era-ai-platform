{
  "name": "new-era-ai-platform",
  "version": "1.8.0-alpha.1",
  "private": true,
  "description": "AI platform for comparing, evaluating and collaborating with multiple AI models.",
  "engines": {
    "node": ">=20.9.0 <25"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:host": "next dev --turbopack --hostname 0.0.0.0",
    "prebuild": "npm run env:check",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "eslint . --fix --cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:env-check": "node --test scripts/check-env.test.mjs",
    "smoke": "node scripts/smoke-check.mjs",
    "health": "node scripts/health-check.mjs",
    "health:local": "node scripts/health-check.mjs local",
    "health:production": "node scripts/health-check.mjs production",
    "env:check": "node scripts/check-env.mjs --mode=basic",
    "env:check:migrations": "node scripts/check-env.mjs --mode=migrations",
    "env:check:full": "node scripts/check-env.mjs --mode=full",
    "env:check:json": "node scripts/check-env.mjs --mode=full --json",
    "env:check:example": "node scripts/check-env.mjs --generate-example",
    "schema:check": "node scripts/check-schema-sync.mjs",
    "models:verify": "node scripts/verify-models.mjs",
    "state:context": "node scripts/state/index.mjs context",
    "state:check": "node scripts/state/index.mjs check",
    "state:task": "node scripts/state/index.mjs task",
    "state:archive": "node scripts/state/index.mjs archive",
    "state:version": "node scripts/state/index.mjs version",
    "docs:sync": "node scripts/sync/index.mjs",
    "docs:check": "node scripts/sync/index.mjs check",
    "docs:restore": "node scripts/sync/index.mjs restore",
    "sync:status": "node scripts/git/sync-after-commit.mjs --dry-run",
    "sync:after-commit": "node scripts/git/sync-after-commit.mjs",
    "sync:install-hook": "git config core.hooksPath .githooks && node -e \"const fs=require('fs');fs.readdirSync('.githooks').forEach(f=>fs.chmodSync('.githooks/'+f,'755'))\"",
    "check": "run-p typecheck lint",
    "verify": "npm run check && npm run build && npm run docs:check",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.108.2",
    "highlight.js": "^11.11.1",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^6.0.0",
    "remark-gfm": "^3.0.1"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-unused-imports": "^4.1.4",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --cache --fix --max-warnings 0"
    ]
  }
}
