# OpenRouter API
# Copy this file to .env.local and fill real values only locally.
# CRITICAL: Never commit .env.local to git repository
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase (for v0.5+)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional server-only key for Supabase persistence.
# Never use this in browser code and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# App settings
APP_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenRouter request limits (read at runtime)
# Prompt length and model-count limits live in src/lib/arena/constants.ts
MODEL_TIMEOUT_MS=60000
OPENROUTER_MAX_TOKENS=1000

# Rate limiting (optional locally, REQUIRED before a public/serverless deploy).
# Without these the limiter is in-memory and does not work across instances.
# Create a free Redis at https://console.upstash.com and paste the REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
