# OpenRouter API
# Reference env catalog only. The primary local template is .env.local.example.
# Copy .env.local.example to .env.local and fill real values only locally.
# CRITICAL: Never commit .env.local to git repository
# Single source of truth for variables: env-check.config.json.
# `npm run env:check:example` regenerates .env.local.example from that config;
# `npm run env:check` validates them. Keep this reference file in sync with
# env-check.config.json and .env.local.example.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase (for v0.5+)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional fallback alias accepted by the client and env checker.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional server-only key for Supabase persistence.
# Never use this in browser code and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Database / migrations (needed for `npm run schema:check` and Supabase CLI).
# Supabase -> Project Settings -> Database -> Connection string (URI).
# DATABASE_URL is accepted as an alias of SUPABASE_DB_URL. Never commit real values.
SUPABASE_DB_URL=
SUPABASE_ACCESS_TOKEN=

# App settings
APP_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature flags
# Set to "true" to enable the /team page. Defaults to disabled (coming soon state).
NEXT_PUBLIC_ENABLE_TEAM_MODE=false

# OpenRouter request limits (read at runtime)
# Prompt length and model-count limits live in src/lib/arena/constants.ts
MODEL_TIMEOUT_MS=60000
OPENROUTER_MAX_TOKENS=1000

# Rate limiting (optional locally, REQUIRED before a public/serverless deploy).
# Without these the limiter is in-memory and does not work across instances.
# Create a free Redis at https://console.upstash.com and paste the REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Deployment Protection automation bypass (optional; server/CI only).
# Used by `npm run smoke` against protected preview deployments.
VERCEL_AUTOMATION_BYPASS_SECRET=
