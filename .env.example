# OpenRouter
# Copy this file to .env.local and fill real values only locally.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=New Era AI Platform

# Supabase public values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only value
# Never expose this key to frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# App settings
APP_ENV=development
APP_URL=http://localhost:3000

# MVP limits
MAX_MODELS_PER_COMPARE=3
MAX_PROMPT_LENGTH=8000
MODEL_TIMEOUT_MS=60000
